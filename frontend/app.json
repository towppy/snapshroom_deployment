{
  "expo": {
    "name": "SnapShroom",
    "slug": "frontend",
    "owner": "towppy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A2318",
        "foregroundImage": "./assets/images/icon.jpg"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.frontend",
      "googleServicesFile": "./google-services.json",
      "versionCode": 11
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.jpg",
      "name": "SnapShroom",
      "shortName": "SnapShroom",
      "themeColor": "#4CAF50",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "07adb69a-bfb4-4df8-96e4-5c90d1a74429"
      }
    }
  }
}
