# ==================================================
# BACKEND API CONFIGURATION
# ==================================================
# IMPORTANT: Change these values when your IP address changes
# You only need to update BACKEND_IP, and all URLs will be constructed automatically

# Your computer's local network IP address (CHANGE THIS)
EXPO_PUBLIC_BACKEND_IP=192.168.1.12
# Backend server port (usually 5000)
EXPO_PUBLIC_BACKEND_PORT=5000
# ngrok forwarding URL (UPDATE when ngrok URL changes)
EXPO_PUBLIC_NGROK_URL=https://your-ngrok-url.ngrok-free.dev

# Constructed API URL (automatically uses the IP and port above)
# You can manually override this if needed, or use the ngrok URL
EXPO_PUBLIC_API_URL=http://192.168.1.12:5000/api
# For ngrok: EXPO_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.dev/api

# ==================================================
# CLOUDINARY CONFIGURATION
# ==================================================
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_API_KEY=your_api_key
EXPO_PUBLIC_CLOUDINARY_API_SECRET=your_api_secret
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
EXPO_PUBLIC_CLOUDINARY_API_URL=https://api.cloudinary.com/v1_1/your_cloud_name/image/upload

# ==================================================
# INSTRUCTIONS
# ==================================================
# 1. Copy this file as .env
# 2. Update EXPO_PUBLIC_BACKEND_IP with your computer's local IP address
# 3. If using ngrok:
#    - Update EXPO_PUBLIC_NGROK_URL with your current ngrok URL
#    - Update EXPO_PUBLIC_API_URL to use the ngrok URL
# 4. Configure Cloudinary credentials
# 5. Restart the Expo development server after changing .env values
